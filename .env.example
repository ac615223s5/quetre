## if set to development, morgan middleware will log every request
NODE_ENV=production 

### optional properties. default shown. enable by removing # in front of them.
# PORT=3000
## duration for which static files' cached copies are valid in the browser(eg: 1m, 3600, '2 days')
# CACHE_PERIOD=1h 
## user agent and accept header that quora will see. a real browser UA is used
## by default(needed so it matches the TLS fingerprint CycleTLS impersonates).
# AXIOS_USER_AGENT='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36'
# AXIOS_ACCEPT='application/json, text/plain, */*'
## for caching api responses using redis
# REDIS_URL=localhost:6379 # if left unset, there'll be no caching
# REDIS_TTL=3600

### cloudflare/TLS-fingerprint evasion (see issue #142).
## requests go through CycleTLS so the TLS fingerprint looks like a real browser.
## the defaults impersonate Chrome and work out of the box; tune only if quora
## starts challenging again. forcing HTTP/3 with a spoofed QUIC fingerprint
## sometimes evades challenges the TLS path can't.
# CYCLETLS_FORCE_HTTP3=1
# CYCLETLS_QUIC_FINGERPRINT='1:65536;6:262144;7:100;51:1;GREASE|GREASE|984832|m,a,s,p'
# CYCLETLS_JA3=
# CYCLETLS_JA4R=
# CYCLETLS_HTTP2_FINGERPRINT=
## route quora requests through a proxy(helps when the server's IP is blocked)
# HTTP_PROXY=http://user:pass@host:8080

### for specific use-cases.
## add any value here (e.g.: 1, true, 'por favor') if you're using any service where http is the preferred method(e.g.: tor, i2p). else leave it blank
NO_UPGRADE=
